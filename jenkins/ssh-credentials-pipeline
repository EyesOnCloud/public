pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                echo "Build stage - no credentials needed here"
                sh 'mkdir -p output && echo "artifact" > output/app.jar'
            }
        }

        stage('Integration Test') {
            steps {
                echo "Integration test stage"

                withCredentials([
                    usernamePassword(
                        credentialsId: 'database-credentials',
                        usernameVariable: 'DB_USER',
                        passwordVariable: 'DB_PASS'
                    )
                ]) {
                    echo "Connecting to test DB as ${env.DB_USER}"

                    sh '''
                        if [ -n "$DB_PASS" ]; then
                            echo "DB auth: OK"
                        else
                            echo "DB auth: FAILED - no password"
                            exit 1
                        fi
                    '''

                    echo "Test DB connection established"
                }

                echo "After withCredentials block"
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploy stage"

                withCredentials([
                    usernamePassword(
                        credentialsId: 'database-credentials',
                        usernameVariable: 'DB_USER',
                        passwordVariable: 'DB_PASS'
                    ),
                    string(
                        credentialsId: 'api-token',
                        variable: 'API_KEY'
                    )
                ]) {
                    echo "Deploying as ${env.DB_USER}"

                    sh 'echo "API call with token: $API_KEY"'
                    sh 'cat output/app.jar'

                    echo "Deploy complete"
                }
            }
        }

        stage('SSH Credential Demo') {
            steps {
                echo "SSH credential injection demo"

                withCredentials([
                    sshUserPrivateKey(
                        credentialsId: 'gitlab-ssh',
                        keyFileVariable: 'SSH_KEY_FILE',
                        usernameVariable: 'SSH_USER'
                    )
                ]) {
                    echo "SSH User     : ${env.SSH_USER}"
                    echo "Key File     : ${env.SSH_KEY_FILE}"

                    sh '''
                        echo "Key file exists: $(test -f $SSH_KEY_FILE && echo YES || echo NO)"
                        echo "Key file permissions:"
                        ls -la $SSH_KEY_FILE
                        echo "SSH user: $SSH_USER"
                    '''
                }

                echo "After block - SSH_KEY_FILE is not accessible"
            }
        }
    }

    post {
        always {
            sh 'rm -rf output/'
            echo "Cleanup done"
        }
    }
}
