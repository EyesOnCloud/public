pipeline {
    agent any

    environment {
        DB_CREDS = credentials('database-credentials')
        API_KEY  = credentials('api-token')
    }

    stages {
        stage('Masking Verification') {
            steps {
                echo "Direct print: ${DB_CREDS_PSW}"
                sh "echo Shell direct: $DB_CREDS_PSW"
                sh 'echo Shell single quote: $DB_CREDS_PSW'
                sh "echo In a string: prefix-${DB_CREDS_PSW}-suffix"
            }
        }
    }
}
